<?xml version="1.0" encoding="UTF-8"?>
<cartridge_basiclti_link xmlns="http://www.imsglobal.org/xsd/imslticc_v1p0"
    xmlns:blti="http://www.imsglobal.org/xsd/imsbasiclti_v1p0"
    xmlns:lticm="http://www.imsglobal.org/xsd/imslticm_v1p0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.imsglobal.org/xsd/imslticc_v1p0 http://www.imsglobal.org/xsd/lti/ltiv1p0/imslticc_v1p0.xsd
                        http://www.imsglobal.org/xsd/imsbasiclti_v1p0 http://www.imsglobal.org/xsd/lti/ltiv1p0/imsbasiclti_v1p0.xsd
                        http://www.imsglobal.org/xsd/imslticm_v1p0 http://www.imsglobal.org/xsd/lti/ltiv1p0/imslticm_v1p0.xsd">

    <blti:title>ASL Express</blti:title>
    <blti:launch_url>https://flowstateasl.onrender.com/api/lti/launch</blti:launch_url>
    <blti:secure_launch_url>https://flowstateasl.onrender.com/api/lti/launch</blti:secure_launch_url>
    
    <blti:extensions platform="canvas.instructure.com">
        <!-- Course Navigation: ASLxpr Flashcards (for practice/study) -->
        <lticm:options name="course_navigation">
            <lticm:property name="text">ASLxpr Flashcards</lticm:property>
            <lticm:property name="url">https://flowstateasl.onrender.com/api/lti/launch/flashcards</lticm:property>
            <lticm:property name="visibility">admins,teachers,students,student_observors</lticm:property>
            <lticm:property name="selection_directive">force_new</lticm:property>
        </lticm:options>
        
        <!-- Course Navigation: ASLxpr Prompt Manager (for teacher configuration) -->
        <lticm:options name="course_navigation">
            <lticm:property name="text">ASLxpr Prompt Manager</lticm:property>
            <lticm:property name="url">https://flowstateasl.onrender.com/api/lti/launch/prompter</lticm:property>
            <lticm:property name="visibility">admins,teachers</lticm:property>
            <lticm:property name="selection_directive">force_new</lticm:property>
        </lticm:options>
        
        <!-- Assignment/Module: ASL Express Assessment (for student submissions) -->
        <lticm:options name="homework_submission">
            <lticm:property name="text">ASL Express Assessment</lticm:property>
            <lticm:property name="url">https://flowstateasl.onrender.com/api/lti/launch/prompter</lticm:property>
        </lticm:options>
        
        <!-- Deep Linking: For creating assignments from modules -->
        <lticm:options name="deep_linking">
            <lticm:property name="text">ASL Express Assessment</lticm:property>
            <lticm:property name="url">https://flowstateasl.onrender.com/api/lti/launch</lticm:property>
        </lticm:options>
    </blti:extensions>
    
    <blti:custom>
        <lticm:property name="course_id">$Canvas.course.id</lticm:property>
        <lticm:property name="assignment_id">$Canvas.assignment.id</lticm:property>
        <lticm:property name="roles">$Canvas.membership.roles</lticm:property>
        <lticm:property name="lis_result_sourcedid">$Canvas.rlis.result_sourcedid</lticm:property>
        <lticm:property name="lis_outcome_service_url">$Canvas.rlis.result_serviceurl</lticm:property>
    </blti:custom>
    
    <blti:description>ASL Express - Video-based vocabulary practice and signing assessments with deck-based prompts.</blti:description>
</cartridge_basiclti_link>