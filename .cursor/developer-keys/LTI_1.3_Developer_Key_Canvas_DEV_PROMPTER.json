{
  "title": "ASL Express – Prompt Manager (Dev)",
  "description": "ASL Express Prompt Manager – local development. Same launch URL as Flashcards (Dev); sends tool_type=prompter.",
  "oidc_initiation_url": "http://localhost:3000/api/lti/oidc/login",
  "target_link_uri": "http://localhost:3000/api/lti/launch",
  "redirect_uris": ["http://localhost:3000/api/lti/launch"],
  "scopes": [
    "https://purl.imsglobal.org/spec/lti-ags/scope/lineitem",
    "https://purl.imsglobal.org/spec/lti-ags/scope/lineitem.readonly",
    "https://purl.imsglobal.org/spec/lti-ags/scope/result.readonly",
    "https://purl.imsglobal.org/spec/lti-ags/scope/score"
  ],
  "extensions": [
    {
      "domain": "localhost",
      "tool_id": "asl-express-prompter-dev",
      "platform": "canvas.instructure.com",
      "privacy_level": "public",
      "settings": {
        "text": "ASL Express – Prompt Manager (Dev)",
        "placements": [
          {
            "placement": "course_navigation",
            "message_type": "LtiResourceLinkRequest",
            "target_link_uri": "http://localhost:3000/api/lti/launch",
            "text": "ASL Express – Prompt Manager (Dev)",
            "selection_height": 800,
            "selection_width": 1000,
            "custom_fields": {
              "course_id": "$Canvas.course.id",
              "assignment_id": "$Canvas.assignment.id",
              "user_id": "$Canvas.user.id",
              "module_id": "$Canvas.module.id",
              "roles": "$Canvas.membership.roles",
              "tool_type": "prompter"
            }
          },
          {
            "placement": "link_selection",
            "message_type": "LtiDeepLinkingRequest",
            "target_link_uri": "http://localhost:3000/api/lti/launch",
            "text": "ASL Express – Prompt Manager (Dev)",
            "selection_height": 600,
            "selection_width": 800,
            "custom_fields": {
              "course_id": "$Canvas.course.id",
              "assignment_id": "$Canvas.assignment.id",
              "user_id": "$Canvas.user.id",
              "module_id": "$Canvas.module.id",
              "roles": "$Canvas.membership.roles",
              "tool_type": "prompter"
            }
          },
          {
            "placement": "homework_submission",
            "message_type": "LtiDeepLinkingRequest",
            "target_link_uri": "http://localhost:3000/api/lti/launch",
            "text": "ASL Express – Record video",
            "selection_width": 1024,
            "selection_height": 768,
            "custom_fields": {
              "course_id": "$Canvas.course.id",
              "assignment_id": "$Canvas.assignment.id",
              "user_id": "$Canvas.user.id",
              "module_id": "$Canvas.module.id",
              "roles": "$Canvas.membership.roles",
              "tool_type": "prompter"
            }
          }
        ]
      }
    }
