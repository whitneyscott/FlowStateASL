<?xml version="1.0" encoding="UTF-8"?>
<!--
  ASL Express Flashcards – LTI 1.1 Configuration for Canvas LMS
  Single tool: Flashcards only. ASL Express Prompter will be a separate tool when developed.
  Base URL: https://flowstateasl.onrender.com (update if using custom domain)

  Instructure-hosted Canvas: JWT iss is often https://canvas.instructure.com, not your school API host.
  The custom fields below pass the real tenant host/base URL for Canvas REST API calls (announcements, assignments, OAuth).

  LTI 1.3 Developer Key: add the same lines under “Custom Fields” (paste or manual):
    canvas_api_domain = $Canvas.api.domain
    canvas_api_base_url = $Canvas.api.baseUrl
-->
<cartridge_basiclti_link xmlns="http://www.imsglobal.org/xsd/imslticc_v1p0"
    xmlns:blti="http://www.imsglobal.org/xsd/imsbasiclti_v1p0"
    xmlns:lticm="http://www.imsglobal.org/xsd/imslticm_v1p0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.imsglobal.org/xsd/imslticc_v1p0 http://www.imsglobal.org/xsd/lti/ltiv1p0/imslticc_v1p0.xsd
                        http://www.imsglobal.org/xsd/imsbasiclti_v1p0 http://www.imsglobal.org/xsd/lti/ltiv1p0/imsbasiclti_v1p0.xsd
                        http://www.imsglobal.org/xsd/imslticm_v1p0 http://www.imsglobal.org/xsd/lti/ltiv1p0/imslticm_v1p0.xsd">

    <blti:title>ASL Express Flashcards</blti:title>
    <blti:description>Interactive ASL vocabulary flashcards with SproutVideo content. Launches the flashcards tool only.</blti:description>
    <blti:launch_url>https://flowstateasl.onrender.com/api/lti/launch/flashcards</blti:launch_url>
    <blti:secure_launch_url>https://flowstateasl.onrender.com/api/lti/launch/flashcards</blti:secure_launch_url>
    
    <blti:extensions platform="canvas.instructure.com">
        <lticm:property name="privacy_level">public</lticm:property>
        <lticm:options name="course_navigation">
            <lticm:property name="text">ASL Express Flashcards</lticm:property>
            <lticm:property name="url">https://flowstateasl.onrender.com/api/lti/launch/flashcards</lticm:property>
            <lticm:property name="visibility">members</lticm:property>
            <lticm:property name="default">enabled</lticm:property>
            <lticm:options name="custom_fields">
                <lticm:property name="custom_roles">$Canvas.membership.roles</lticm:property>
                <lticm:property name="custom_canvas_api_base_url">$Canvas.api.baseUrl</lticm:property>
                <lticm:property name="custom_canvas_domain">$Canvas.api.domain</lticm:property>
            </lticm:options>
        </lticm:options>
    </blti:extensions>
    
    <blti:custom>
        <lticm:property name="custom_activity_type">flashcards</lticm:property>
        <lticm:property name="custom_canvas_api_base_url">$Canvas.api.baseUrl</lticm:property>
        <lticm:property name="custom_canvas_domain">$Canvas.api.domain</lticm:property>
        <lticm:property name="custom_canvas_course_id">$Canvas.course.id</lticm:property>
        <lticm:property name="custom_canvas_assignment_id">$Canvas.assignment.id</lticm:property>
        <lticm:property name="custom_canvas_user_id">$Canvas.user.id</lticm:property>
        <lticm:property name="custom_module_id">$Canvas.module.id</lticm:property>
        <lticm:property name="custom_roles">$Canvas.membership.roles</lticm:property>
    </blti:custom>
    
    <blti:launch_height>800</blti:launch_height>
    <blti:launch_width>1000</blti:launch_width>
    <blti:presentation_document_target>iframe</blti:presentation_document_target>
</cartridge_basiclti_link>
