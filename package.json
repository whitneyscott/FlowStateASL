{
  "name": "@aslexpress/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "nx run-many -t build",
    "build:api": "nx build api",
    "build:web": "nx build web",
    "serve": "nx run-many -t serve --parallel=2",
    "kill-ports": "kill-port 3000 4200 9229",
    "start:dev": "run-s kill-ports start:dev:run",
    "start:dev:run": "nx run-many -t serve --parallel=2",
    "serve:api": "nx serve api",
    "serve:web": "nx serve web",
    "lint": "nx run-many -t lint",
    "test:regression:flashcard": "tsx --tsconfig apps/api/tsconfig.json apps/api/src/scripts/regression-flashcard-routes.ts",
    "seed:qti": "tsx --tsconfig apps/api/tsconfig.json apps/api/src/scripts/seed-qti.ts",
    "db:migrate": "nx run api:build && npx typeorm migration:run -d dist/apps/api/src/data/data-source.js",
    "seed:sprout:fresh": "tsx --tsconfig apps/api/tsconfig.json apps/api/src/scripts/seed-sprout-fresh.ts",
    "validate:lti-click": "node scripts/validate-lti-module-click.mjs"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/typeorm": "^10.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "adm-zip": "^0.5.16",
    "connect-pg-simple": "^10.0.0",
    "express-session": "^1.18.1",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwk-to-pem": "^2.0.7",
    "oauth-signature": "^1.5.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nx/js": "22.5.2",
    "@nx/vite": "22.5.2",
    "@nx/workspace": "22.5.2",
    "@types/adm-zip": "^0.5.7",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.5",
    "kill-port": "^2.0.1",
    "npm-run-all": "^4.1.5",
    "nx": "22.5.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
