DATABASE_URL=postgresql://user:pass@localhost:5432/aslexpress?sslmode=require
SESSION_SECRET=change-me-in-production
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
SPROUT_KEY=
SPROUT_ACCOUNT_ID=
CANVAS_API_TOKEN=
# Optional when launched via LTI (domain auto-extracted from launch); fallback for edge cases
CANVAS_DOMAIN=
CURRICULUM_PREFIX=TWA

# Local dev: base URL for the API. Must match Canvas Developer Key redirect URIs.
APP_URL=http://localhost:3000

# LTI 1.3 (local dev: must match Redirect URI in Canvas LTI Developer Key)
LTI_CLIENT_ID=
LTI_REDIRECT_URI=http://localhost:3000/api/lti/launch
# Optional: PEM private key for JWT signing. If not set, a key is generated at startup (dev only).
# LTI_PRIVATE_KEY=
