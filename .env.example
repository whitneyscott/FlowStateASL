DATABASE_URL=postgresql://user:pass@localhost:5432/aslexpress?sslmode=require
SESSION_SECRET=change-me-in-production
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
# Web mode password (Bulk Editor-style variable name). Used by Mode button for Developer/Production.
# MODE_PASSWORD=
SPROUT_KEY=
SPROUT_ACCOUNT_ID=
# Optional dev fallback: Canvas API base URL. In production, base URL comes from each LTI launch (JWT iss / consumer URL).
# Only set this for local scripts or tests that call Canvas without an LTI session.
CANVAS_API_BASE_URL=
CURRICULUM_PREFIX=TWA

# Local dev: base URL for the API. Must match Canvas Developer Key redirect URIs.
APP_URL=http://localhost:3000
# When Canvas runs in Docker: host reachable from container (e.g. http://172.22.0.1:3000). Used for content_items file URL and public_jwk_url.
CANVAS_INTERNAL_URL=

# LTI 1.3 (must match Canvas Developer Keys). Required for launch and Deep Linking (video submission).
LTI_CLIENT_ID=
# Prompter Developer Key client ID (for Deep Linking response iss and Prompter AGS). Required when using Prompter tool.
LTI_PROMPTER_CLIENT_ID=
# Optional: numeric Context External Tool ID for this course (Canvas URL .../external_tools/THIS_ID). Skips listing tools when auto-adding the Prompter link to a module.
# CANVAS_PROMPTER_EXTERNAL_TOOL_ID=
LTI_REDIRECT_URI=http://localhost:3000/api/lti/launch
# Required: Full PEM private key for JWT signing (Deep Linking response, AGS). Use double quotes with \n for newlines.
# LTI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----"

# Optional static Canvas access tokens when users have no OAuth (typical students). The API picks one by Canvas REST host:
#   localhost / 127.0.0.1 → CANVAS_API_TOKEN_LOCAL (local Canvas OSS Docker)
#   canvas.instructure.com (FFT cloud) → CANVAS_API_TOKEN_FFT
#   Host matching tjc.instructure.com / *.tjc.edu → CANVAS_API_TOKEN_TJC (override substrings: CANVAS_API_TOKEN_MATCH_TJC=)
# Fallback if host unmatched: CANVAS_API_TOKEN_TJC, then CANVAS_API_TOKEN, then CANVAS_ACCESS_TOKEN
# CANVAS_API_TOKEN_LOCAL=
# CANVAS_API_TOKEN_FFT=
# CANVAS_API_TOKEN_TJC=
# CANVAS_API_TOKEN=
# CANVAS_ACCESS_TOKEN=

# Canvas OAuth (required for teacher Canvas API calls; domain from LTI iss)
CANVAS_OAUTH_CLIENT_ID=
CANVAS_OAUTH_CLIENT_SECRET=
CANVAS_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/canvas/callback
# AES-256-GCM key for encrypting manual Canvas API tokens in course_settings (LTI 1.1). Required for durable token storage.
# Generate: openssl rand -hex 32
# CANVAS_TOKEN_ENCRYPTION_KEY=
# When the Canvas Developer Key has "Enforce Scopes", OAuth must request scopes (defaults are built in). Set to off only for legacy keys.
# CANVAS_OAUTH_SCOPE_MODE=off
# CANVAS_OAUTH_SCOPES=url:GET|/api/v1/users/self ...

# LTI 1.1 (OAuth 1.0a) — shared secret for backward compatibility. Used when Canvas POSTs oauth_consumer_key+oauth_signature to /api/lti/launch.
# Prefer LTI11_SHARED_SECRET; alternatives: LTI_1_1_SHARED_SECRET, LTI1_SHARED_SECRET, LTI_SHARED_SECRET.
# Optional multi-key: LTI11_SECRETS_JSON={"consumer_key":"secret",...}
LTI11_SHARED_SECRET=
