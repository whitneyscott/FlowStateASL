{
  "title": "ASL Express – Prompt Manager",
  "description": "ASL Express Prompt Manager (Prompter). Same launch URL as Flashcards; sends tool_type=prompter so the app opens the Prompter UI.",
  "oidc_initiation_url": "https://flowstateasl.onrender.com/api/lti/oidc/login",
  "target_link_uri": "https://flowstateasl.onrender.com/api/lti/launch",
  "redirect_uris": ["https://flowstateasl.onrender.com/api/lti/launch"],
  "scopes": [],
  "extensions": [
    {
      "domain": "flowstateasl.onrender.com",
      "tool_id": "asl-express-prompter",
      "platform": "canvas.instructure.com",
      "privacy_level": "public",
      "settings": {
        "text": "ASL Express – Prompt Manager",
        "placements": [
          {
            "placement": "course_navigation",
            "message_type": "LtiResourceLinkRequest",
            "target_link_uri": "https://flowstateasl.onrender.com/api/lti/launch",
            "text": "ASL Express – Prompt Manager",
            "selection_height": 800,
            "selection_width": 1000,
            "custom_fields": {
              "course_id": "$Canvas.course.id",
              "assignment_id": "$Canvas.assignment.id",
              "user_id": "$Canvas.user.id",
              "module_id": "$Canvas.module.id",
              "roles": "$Canvas.membership.roles",
              "tool_type": "prompter"
            }
          },
          {
            "placement": "link_selection",
            "message_type": "LtiDeepLinkingRequest",
            "target_link_uri": "https://flowstateasl.onrender.com/api/lti/launch",
            "text": "ASL Express – Prompt Manager",
            "selection_height": 600,
            "selection_width": 800,
            "custom_fields": {
              "course_id": "$Canvas.course.id",
              "assignment_id": "$Canvas.assignment.id",
              "user_id": "$Canvas.user.id",
              "module_id": "$Canvas.module.id",
              "roles": "$Canvas.membership.roles",
              "tool_type": "prompter"
            }
          }
        ]
      }
    }
  ],
  "public_jwk_url": "https://flowstateasl.onrender.com/api/lti/jwks",
  "custom_fields": {
    "course_id": "$Canvas.course.id",
    "assignment_id": "$Canvas.assignment.id",
    "user_id": "$Canvas.user.id",
    "module_id": "$Canvas.module.id",
    "roles": "$Canvas.membership.roles",
    "tool_type": "prompter"
  }
}
